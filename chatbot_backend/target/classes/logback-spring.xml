<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ─── Common Properties ─────────────────────────────────────────────── -->
    <property name="LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} [%thread] [%X{correlationId}] %-5level %logger{36} - %msg%n"/>

    <!-- ─── Production Profile: JSON structured logging ───────────────────── -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>correlationId</includeMdcKeyName>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>

        <!-- Package-specific levels for prod -->
        <logger name="com.xpressbees.chatbot" level="INFO"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>

    <!-- ─── Dev and Staging Profiles: human-readable pattern layout ────────── -->
    <springProfile name="dev | staging">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- Package-specific levels for dev/staging -->
        <logger name="com.xpressbees.chatbot" level="DEBUG"/>
        <logger name="org.springframework" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
    </springProfile>

    <!-- ─── Default (no profile active) fallback ──────────────────────────── -->
    <springProfile name="default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.xpressbees.chatbot" level="DEBUG"/>
    </springProfile>

</configuration>
